<?xml version="1.0" encoding="utf-8"?>
<!--
    Adaptive icon foreground: mic inside a watch bezel ring.
    Canvas: 108×108dp. Safe zone: 66dp circle centred at 54,54.
    Bezel ring sits at the safe-zone edge (r=40) to suggest a watch case.
    Mic is the Material Design microphone path, scaled 2× and centred.
-->
<vector xmlns:android="http://schemas.android.com/apk/res/android"
    android:width="108dp"
    android:height="108dp"
    android:viewportWidth="108"
    android:viewportHeight="108">

    <!-- Watch bezel ring (r=40, strokeWidth=5) -->
    <path
        android:pathData="M54,54 m-40,0 a40,40 0 1,0 80,0 a40,40 0 1,0 -80,0"
        android:fillColor="#00000000"
        android:strokeColor="#FFFFFF"
        android:strokeWidth="5"/>

    <!-- Mic icon: Material mic path scaled 2× (+30,+30 translate to centre) -->
    <group
        android:translateX="30"
        android:translateY="30"
        android:scaleX="2.0"
        android:scaleY="2.0">
        <!-- Mic capsule body -->
        <path
            android:fillColor="#FFFFFF"
            android:pathData="M12,14c1.66,0 2.99,-1.34 2.99,-3L15,5c0,-1.66 -1.34,-3 -3,-3S9,3.34 9,5v6c0,1.66 1.34,3 3,3z"/>
        <!-- Mic stand + base -->
        <path
            android:fillColor="#FFFFFF"
            android:pathData="M17.3,11c0,3 -2.54,5.1 -5.3,5.1S6.7,14 6.7,11L5,11c0,3.41 2.72,6.23 6,6.72L11,21h2v-3.28c3.28,-0.48 6,-3.3 6,-6.72h-1.7z"/>
    </group>

</vector>
