<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android">

    <!-- Internet for Omi API -->
    <uses-permission android:name="android.permission.INTERNET" />
    <uses-permission android:name="android.permission.ACCESS_NETWORK_STATE" />

    <!-- Foreground service for audio upload -->
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_SPECIAL_USE" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_DATA_SYNC" />

    <!-- Post notifications (Android 13+) -->
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />

    <!-- Wake lock -->
    <uses-permission android:name="android.permission.WAKE_LOCK" />

    <!-- Request battery optimization exemption so Samsung won't freeze the process -->
    <uses-permission android:name="android.permission.REQUEST_IGNORE_BATTERY_OPTIMIZATIONS" />

    <application
        android:allowBackup="true"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:supportsRtl="true"
        android:theme="@style/Theme.Material3.DayNight.NoActionBar">

        <!-- Main Activity -->
        <activity
            android:name=".MainActivity"
            android:exported="true"
            android:theme="@style/Theme.Material3.DayNight.NoActionBar">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <!-- Wearable Listener Service - receives audio from watch -->
        <service
            android:name=".service.AudioReceiverService"
            android:exported="true"
            android:permission="com.google.android.gms.permission.BIND_LISTENER_SERVICE">
            <intent-filter>
                <action android:name="com.google.android.gms.wearable.MESSAGE_RECEIVED" />
                <data
                    android:host="*"
                    android:pathPrefix="/audio"
                    android:scheme="wear" />
            </intent-filter>
            <intent-filter>
                <action android:name="com.google.android.gms.wearable.DATA_CHANGED" />
                <data
                    android:host="*"
                    android:pathPrefix="/audio"
                    android:scheme="wear" />
            </intent-filter>
        </service>

        <!-- Persistent foreground service — keeps process alive so Samsung can't freeze it -->
        <service
            android:name=".service.WatchReceiverService"
            android:exported="false"
            android:foregroundServiceType="dataSync" />

        <!-- Audio Upload Service -->
        <service
            android:name=".service.AudioUploadService"
            android:exported="false"
            android:foregroundServiceType="specialUse" />

        <!-- Declare wearable capability for watch discovery -->
        <meta-data
            android:name="com.google.android.gms.version"
            android:value="@integer/google_play_services_version" />

        <!-- FileProvider for sharing audio files to SpeechRecognizer -->
        <provider
            android:name="androidx.core.content.FileProvider"
            android:authorities="com.omi4wos.fileprovider"
            android:exported="false"
            android:grantUriPermissions="true">
            <meta-data
                android:name="android.support.FILE_PROVIDER_PATHS"
                android:resource="@xml/file_paths" />
        </provider>

    </application>

</manifest>
