<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android">

    <!-- Audio recording -->
    <uses-permission android:name="android.permission.RECORD_AUDIO" />

    <!-- Foreground service -->
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_MICROPHONE" />

    <!-- Keep CPU alive during recording -->
    <uses-permission android:name="android.permission.WAKE_LOCK" />

    <!-- Vibration for speech detection feedback -->
    <uses-permission android:name="android.permission.VIBRATE" />

    <!-- Request battery optimization exemption -->
    <uses-permission android:name="android.permission.REQUEST_IGNORE_BATTERY_OPTIMIZATIONS" />

    <!-- Standalone build: direct upload to Omi Cloud -->
    <uses-permission android:name="android.permission.INTERNET" />
    <uses-permission android:name="android.permission.ACCESS_NETWORK_STATE" />

    <!-- Post notifications (Android 13+) -->
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />

    <!-- Body sensors for WearOS -->
    <uses-permission android:name="android.permission.BODY_SENSORS" />

    <!-- Declare this is a Wear OS app -->
    <uses-feature android:name="android.hardware.type.watch" />

    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_DATA_SYNC" />

    <application
        android:allowBackup="true"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:supportsRtl="true"
        android:theme="@android:style/Theme.DeviceDefault">
        <profileable android:shell="true" />
        <!-- Main Activity -->
        <activity
            android:name=".MainActivity"
            android:exported="true"
            android:taskAffinity=""
            android:theme="@android:style/Theme.DeviceDefault">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <!-- Audio Capture Foreground Service (companion build) -->
        <service
            android:name=".service.AudioCaptureService"
            android:exported="false"
            android:foregroundServiceType="microphone|dataSync" />

        <!-- Standalone Audio Capture Foreground Service (no phone companion required) -->
        <service
            android:name=".service.StandaloneAudioCaptureService"
            android:exported="false"
            android:foregroundServiceType="microphone" />

        <!-- Receives start/stop/force-sync commands from the phone companion app -->
        <service
            android:name=".service.WatchCommandReceiver"
            android:exported="true">
            <intent-filter>
                <action android:name="com.google.android.gms.wearable.MESSAGE_RECEIVED" />
                <data
                    android:host="*"
                    android:pathPrefix="/audio/control"
                    android:scheme="wear" />
            </intent-filter>
        </service>

        <!-- Tile Service -->
        <service
            android:name=".tile.Omi4wosTileService"
            android:exported="true"
            android:label="@string/tile_label"
            android:permission="com.google.android.wearable.permission.BIND_TILE_PROVIDER">
            <intent-filter>
                <action android:name="androidx.wear.tiles.action.BIND_TILE_PROVIDER" />
            </intent-filter>

            <meta-data
                android:name="androidx.wear.tiles.PREVIEW"
                android:resource="@drawable/ic_mic" />
        </service>

        <!-- Declare wearable capability for phone discovery -->
        <meta-data
            android:name="com.google.android.gms.version"
            android:value="@integer/google_play_services_version" />

    </application>

</manifest>
